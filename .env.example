# ─────────────────────────────────────────────────────────────────────────────
#  PolyTrack Bot — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
#  HOW TO GET YOUR BOT TOKEN:
#  1. Open Telegram and search for @BotFather
#  2. Send /newbot and follow the prompts (choose name + username)
#  3. BotFather will reply with a token like: 123456789:AAF...xyz
#  4. Copy that token and paste it below (remove the placeholder)
#
#  ⚠️  NEVER commit the real .env file to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

BOT_TOKEN=8343949676:AAF0XVNI9-7-BgKPc-xOi9PSzEeKO-Hb3YM

# Optional: how often (seconds) to poll Polymarket for new trades (default 45)
POLL_INTERVAL=45

# Optional: path to SQLite DB file (default: polytrack.db in project root)
DB_PATH=polytrack.db

# Optional: log level — DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
